{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(*)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(yarn *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(git merge*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git tag*)",
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(git show*)",
      "Bash(git remote*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(tsc *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(jq *)",
      "Bash(gh *)",
      "Bash(psql *)",
      "Bash(redis-cli *)",
      "Bash(k6 *)",
      "Bash(artillery *)",
      "Bash(ffmpeg *)",
      "Bash(convert *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(xargs *)",
      "Bash(open *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(date *)",
      "Bash(uptime *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(ps *)",
      "Bash(kill *)",
      "Bash(lsof *)",
      "Bash(netstat *)",
      "Bash(ping *)",
      "Bash(ssh *)",
      "Bash(scp *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'rm -rf\\|drop table\\|delete from\\|truncate\\|format c:'; then echo 'UYARI: Yıkıcı komut tespit edildi. Devam etmek için onay gerekli.' >&2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date '+%H:%M:%S')] Dosya güncellendi: $CLAUDE_TOOL_OUTPUT\" >> /tmp/ai-team-activity.log 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'git commit'; then echo \"[$(date '+%H:%M:%S')] Git commit yapıldı\" >> /tmp/ai-team-activity.log 2>/dev/null || true; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f /tmp/ai-team-activity.log ]; then COUNT=$(wc -l < /tmp/ai-team-activity.log); echo \"\\n📊 Bu oturumda $COUNT işlem gerçekleştirildi.\"; rm -f /tmp/ai-team-activity.log; fi 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
