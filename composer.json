{
    "name": "zirvedonusum/api-client",
    "description": "Zirve Dönüşüm Multi-Portal E-Dönüşüm API Client (Mikro + Zirve Portal + GIB + Paraşüt + Logo Tiger + Uyumsoft) for PHP/Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sercan Ozbilek"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "ZirveDonusum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZirveDonusum\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ZirveDonusum\\ZirveDonusumServiceProvider"
            ],
            "aliases": {
                "ZirveDonusum": "ZirveDonusum\\Facades\\ZirveDonusum",
                "MikroPortal": "ZirveDonusum\\Facades\\MikroPortal",
                "ZirvePortal": "ZirveDonusum\\Facades\\ZirvePortal",
                "GibPortal": "ZirveDonusum\\Facades\\GibPortal",
                "Parasut": "ZirveDonusum\\Facades\\Parasut",
                "LogoTiger": "ZirveDonusum\\Facades\\LogoTiger",
                "Uyumsoft": "ZirveDonusum\\Facades\\Uyumsoft"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
