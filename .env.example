# ───────────────────────────────────────────────────────────────────
# Varsayılan client (geriye uyumluluk için 'zirve-donusum' alias'ı)
# mikro | zirve | gib | parasut | logo_tiger | uyumsoft
# ───────────────────────────────────────────────────────────────────
EDONUSUM_DEFAULT=zirve

# ───────────────────────────────────────────────────────────────────
# Mikro Portal (eportal.mikrogrup.com)
# ───────────────────────────────────────────────────────────────────
EMIKRO_BASE_URL=https://eportal.mikrogrup.com
EMIKRO_EMAIL=
EMIKRO_PASSWORD=
EMIKRO_TIMEOUT=30
EMIKRO_VERIFY_SSL=true
EMIKRO_CACHE_SESSION=true
EMIKRO_SESSION_TTL=82800

# ───────────────────────────────────────────────────────────────────
# Zirve Portal (yeniportal.zirvedonusum.com)
# ───────────────────────────────────────────────────────────────────
ZIRVE_BASE_URL=https://yeniportal.zirvedonusum.com/accounting/api
ZIRVE_USERNAME=
ZIRVE_PASSWORD=
ZIRVE_TIMEOUT=30
ZIRVE_VERIFY_SSL=true
ZIRVE_CACHE_TOKEN=true
ZIRVE_TOKEN_TTL=82800

# ───────────────────────────────────────────────────────────────────
# GİB e-Arşiv Portal (earsivportal.efatura.gov.tr)
# ───────────────────────────────────────────────────────────────────
GIB_BASE_URL=https://earsivportal.efatura.gov.tr
GIB_USERNAME=
GIB_PASSWORD=
GIB_TEST_MODE=false
GIB_TIMEOUT=30
GIB_VERIFY_SSL=false
GIB_CACHE_TOKEN=true
GIB_TOKEN_TTL=3600

# ───────────────────────────────────────────────────────────────────
# Paraşüt V4 (api.parasut.com)
# OAuth2 password grant. Geliştirici hesabı: api.parasut.com/oauth/applications
# ───────────────────────────────────────────────────────────────────
PARASUT_BASE_URL=https://api.parasut.com/v4
PARASUT_AUTH_URL=https://api.parasut.com/oauth/token
PARASUT_USERNAME=
PARASUT_PASSWORD=
PARASUT_COMPANY_ID=
PARASUT_CLIENT_ID=
PARASUT_CLIENT_SECRET=
PARASUT_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
PARASUT_TIMEOUT=30
PARASUT_VERIFY_SSL=true
PARASUT_CACHE_TOKEN=true
PARASUT_TOKEN_TTL=7200

# ───────────────────────────────────────────────────────────────────
# Logo Tiger REST API (Logo Connect)
# Tipik kurulum: lokal Logo Connect servis (port 32001)
# ───────────────────────────────────────────────────────────────────
LOGO_TIGER_BASE_URL=http://localhost:32001/api/v1/
LOGO_TIGER_USERNAME=
LOGO_TIGER_PASSWORD=
LOGO_TIGER_FIRMA_NO=1
LOGO_TIGER_DONEM_NO=1
LOGO_TIGER_GRANT_TYPE=password
LOGO_TIGER_CLIENT_ID=logo
LOGO_TIGER_TIMEOUT=30
LOGO_TIGER_VERIFY_SSL=false
LOGO_TIGER_CACHE_TOKEN=true
LOGO_TIGER_TOKEN_TTL=1800

# ───────────────────────────────────────────────────────────────────
# Uyumsoft E-Fatura / E-Arşiv / E-İrsaliye
# Test:  https://efatura-test.uyumsoft.com.tr
# Prod:  https://efatura.uyumsoft.com.tr
# ───────────────────────────────────────────────────────────────────
UYUMSOFT_BASE_URL=
UYUMSOFT_USERNAME=
UYUMSOFT_PASSWORD=
UYUMSOFT_TEST_MODE=true
UYUMSOFT_TIMEOUT=30
UYUMSOFT_VERIFY_SSL=true
